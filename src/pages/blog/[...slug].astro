---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description} type="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.date.toISOString(),
      "author": {
        "@type": "Person",
        "name": "Jose F. Brevil, Jr.",
        "url": "https://josebrevil.com",
      },
    })} />
  </Fragment>
  <div class="container page-content">
    <a href="/blog" class="back-link">← All posts</a>

    <article>
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <time datetime={post.data.date.toISOString()} class="post-date">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 64px;
  padding-bottom: 80px;
  max-width: var(--content-width);
}

.back-link {
  display: inline-block;
  font-size: 14px;
  color: var(--color-accent);
  margin-bottom: 32px;
}

.post-header {
  margin-bottom: 40px;
}

.post-header h1 {
  margin-bottom: 8px;
}

.post-date {
  font-size: 14px;
  color: var(--color-secondary);
}

/* Prose styles for Markdown content */
.prose :global(h2) { margin-top: 40px; margin-bottom: 12px; }
.prose :global(h3) { margin-top: 28px; margin-bottom: 8px; }
.prose :global(p)  { margin-bottom: 16px; }
.prose :global(ul),
.prose :global(ol) { padding-left: 24px; margin-bottom: 16px; }
.prose :global(li) { margin-bottom: 4px; }
.prose :global(blockquote) {
  border-left: 3px solid var(--color-accent);
  padding-left: 16px;
  color: var(--color-secondary);
  margin: 24px 0;
}
.prose :global(code) {
  background: #f4f4f4;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 0.9em;
}
.prose :global(pre) {
  background: #f4f4f4;
  padding: 20px;
  border-radius: 4px;
  overflow-x: auto;
  margin-bottom: 16px;
}
.prose :global(pre code) { background: none; padding: 0; }
.prose :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 40px 0; }
</style>
