---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('experience');
const sorted = all.sort((a, b) => a.data.order - b.data.order);

const education    = sorted.filter(e => e.data.section === 'education');
const professional = sorted.filter(e => e.data.section === 'professional');
const leadership   = sorted.filter(e => e.data.section === 'leadership');
const skills       = sorted.filter(e => e.data.section === 'skills');
---

<BaseLayout title="Experience">
  <div class="container page-content">

    <!-- Education -->
    <section class="section">
      <h2 class="section-heading">Education</h2>
      {education.map(entry => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-title">{entry.data.title}</span>
            <span class="entry-date">{entry.data.location}</span>
          </div>
          <div class="entry-sub">{entry.data.subtitle}</div>
          {entry.data.bullets.map(bullet => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

    <!-- Professional Experience -->
    <section class="section">
      <h2 class="section-heading">Professional Experience</h2>
      {professional.map(entry => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-title">{entry.data.title}</span>
            <span class="entry-date">{entry.data.location}</span>
          </div>
          <div class="entry-sub">{entry.data.subtitle}</div>
          {entry.data.bullets.map(bullet => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

    <!-- Leadership & Activities -->
    <section class="section">
      <h2 class="section-heading">Leadership &amp; Activities</h2>
      {leadership.map(entry => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-title">{entry.data.title}</span>
            <span class="entry-date">{entry.data.location}</span>
          </div>
          <div class="entry-sub">{entry.data.subtitle}</div>
          {entry.data.bullets.map(bullet => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

    <!-- Skills & Certifications -->
    <section class="section">
      <h2 class="section-heading">Skills &amp; Certifications</h2>
      {skills.map(entry => (
        <div class="entry">
          <p class="subsection-label">{entry.data.title}</p>
          {entry.data.bullets.map(bullet => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 80px;
  padding-bottom: 60px;
}

.section {
  max-width: var(--content-width);
  margin-bottom: 56px;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.section-heading,
.entry {
  opacity: 0;
}
.section-heading.visible,
.entry.visible {
  animation: fadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.section-heading, .entry').forEach(el => {
    observer.observe(el);
  });
</script>
