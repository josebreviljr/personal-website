---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from '../lib/sanity';

const all = await sanityClient.fetch(`*[_type == "experience"] | order(order asc)`);

const education    = all.filter((e: any) => e.section === 'education');
const professional = all.filter((e: any) => e.section === 'professional');
const leadership   = all.filter((e: any) => e.section === 'leadership');
const skills       = all.filter((e: any) => e.section === 'skills');
---

<BaseLayout title="Experience">
  <div class="container page-content">

    <!-- Education -->
    <section class="section">
      <h2 class="section-heading">Education</h2>
      {education.map((entry: any) => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-title">{entry.title}</span>
            <span class="entry-date">{entry.location}</span>
          </div>
          <div class="entry-sub">{entry.subtitle}</div>
          {entry.bullets.map((bullet: string) => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

    <!-- Professional Experience -->
    <section class="section">
      <h2 class="section-heading">Professional Experience</h2>
      {professional.map((entry: any) => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-title">{entry.title}</span>
            <span class="entry-date">{entry.location}</span>
          </div>
          <div class="entry-sub">{entry.subtitle}</div>
          {entry.bullets.map((bullet: string) => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

    <!-- Leadership & Activities -->
    <section class="section">
      <h2 class="section-heading">Leadership &amp; Activities</h2>
      {leadership.map((entry: any) => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-title">{entry.title}</span>
            <span class="entry-date">{entry.location}</span>
          </div>
          <div class="entry-sub">{entry.subtitle}</div>
          {entry.bullets.map((bullet: string) => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

    <!-- Skills & Certifications -->
    <section class="section">
      <h2 class="section-heading">Skills &amp; Certifications</h2>
      {skills.map((entry: any) => (
        <div class="entry">
          <p class="subsection-label">{entry.title}</p>
          {entry.bullets.map((bullet: string) => (
            <p class="entry-bullet">· {bullet}</p>
          ))}
        </div>
      ))}
    </section>

  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 80px;
  padding-bottom: 60px;
}

.section {
  max-width: var(--content-width);
  margin-bottom: 56px;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.section-heading,
.entry {
  opacity: 0;
}
.section-heading.visible,
.entry.visible {
  animation: fadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.section-heading, .entry').forEach(el => {
    observer.observe(el);
  });
</script>
