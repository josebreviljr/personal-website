---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Experience">
  <div class="container page-content">

    <!-- Academic Experience -->
    <section class="section">
      <h2 class="section-heading">Academic Experience</h2>

      <p class="subsection-label">Research Positions</p>

      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">[Lab Name / Research Group]</span>
          <span class="entry-date">[Fall 20XX – Present]</span>
        </div>
        <p class="entry-sub">Supervisor: [Professor Name]</p>
        <p class="entry-body">
          [Description of research responsibilities, methodologies employed, and contributions
          to the lab's broader research agenda.]
        </p>
      </div>
    </section>

    <!-- Work Experience -->
    <section class="section">
      <h2 class="section-heading">Work Experience</h2>

      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">[Job Title], [Organization]</span>
          <span class="entry-date">[Month Year] – [Month Year]</span>
        </div>
        <p class="entry-bullet">· [Managed [responsibility], supporting [team/initiative] in achieving [goal]]</p>
        <p class="entry-bullet">· [Coordinated [event/program] for [number] participants, improving [metric] by [amount]]</p>
      </div>

      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">[Job Title], [Organization]</span>
          <span class="entry-date">[Month Year] – [Month Year]</span>
        </div>
        <p class="entry-bullet">· [Led [initiative], resulting in [outcome]]</p>
      </div>
    </section>

    <!-- Campus Involvement -->
    <section class="section">
      <h2 class="section-heading">Campus Involvement</h2>

      <ul class="involvement-list">
        <li class="involvement-item">
          <span class="involvement-name">[Organization Name], [Role/Position]</span>
          <span class="involvement-year">[20XX – 20XX]</span>
        </li>
        <li class="involvement-item">
          <span class="involvement-name">[Organization Name], [Role/Position]</span>
          <span class="involvement-year">[20XX – 20XX]</span>
        </li>
        <li class="involvement-item">
          <span class="involvement-name">[Organization Name], [Role/Position]</span>
          <span class="involvement-year">[20XX – Present]</span>
        </li>
      </ul>
    </section>

    <!-- Awards & Honors -->
    <section class="section">
      <h2 class="section-heading">Awards &amp; Honors</h2>

      <ul class="awards-list">
        <li class="award-item">
          <span class="award-name">[Award Name], [Institution/Organization]</span>
          <span class="award-year">[Year]</span>
        </li>
        <li class="award-item">
          <span class="award-name">[Scholarship/Fellowship Name], [University]</span>
          <span class="award-year">[Year]</span>
        </li>
        <li class="award-item">
          <span class="award-name">[Dean's List / Honor Society], [University]</span>
          <span class="award-year">[Year – Year]</span>
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 80px;
  padding-bottom: 60px;
}

.section {
  max-width: var(--content-width);
  margin-bottom: 56px;
}

.involvement-list,
.awards-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.involvement-item,
.award-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16px;
}

.involvement-name,
.award-name {
  font-size: 15px;
}

.involvement-year,
.award-year {
  font-size: 14px;
  color: var(--color-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}
</style>
