---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from '../lib/sanity';

const bio = await sanityClient.fetch(`*[_type == "bio"][0]{
  resumePdf { asset->{ url } },
  resumePages[] { asset->{ url } }
}`);

const pages: string[] = bio?.resumePages?.map((p: any) => p.asset.url) ?? [];
const pdfUrl: string = bio?.resumePdf?.asset?.url ?? '/resume.pdf';
---

<BaseLayout title="CV">
  <div class="cv-wrap">
    {pages.map((src, i) => (
      <div class="cv-page">
        <a href={pdfUrl} target="_blank" rel="noopener">
          <img src={src} alt={`Résumé page ${i + 1}`} />
        </a>
      </div>
    ))}

    <div class="cv-download">
      <a href={pdfUrl} download class="download-btn">Download CV</a>
    </div>
  </div>
</BaseLayout>

<style>
.cv-wrap {
  background: #fff;
  padding: 48px 24px 64px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.cv-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 760px;
}

.cv-page a {
  display: block;
  width: 100%;
  box-shadow: 0 2px 12px rgba(0,0,0,0.12);
}

.cv-page img {
  display: block;
  width: 100%;
  height: auto;
}

.cv-download {
  margin-top: 8px;
}

.download-btn {
  display: inline-block;
  padding: 10px 28px;
  background: var(--color-accent);
  color: #fff;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 700;
  border-radius: 3px;
  text-decoration: none;
  transition: opacity 0.15s;
}
.download-btn:hover { opacity: 0.88; text-decoration: none; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.cv-wrap {
  opacity: 0;
}
.cv-wrap.visible {
  animation: fadeIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
</style>

<script>
  document.querySelector('.cv-wrap')?.classList.add('visible');
</script>
