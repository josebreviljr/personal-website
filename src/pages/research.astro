---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Research & Writing">
  <div class="container page-content">

    <!-- Research Interests -->
    <section class="section">
      <h2 class="section-heading">Research Interests</h2>
      <p>
        [My research interests span [field 1], [field 2], and [field 3]. I am particularly
        interested in understanding how [phenomenon] shapes [outcome], and what role
        [mechanism] plays in [broader context]. My work draws on methods from [disciplines],
        with attention to [theoretical framework or approach].]
      </p>
    </section>

    <!-- Thesis / Independent Research -->
    <section class="section">
      <h2 class="section-heading">Independent Research / Honors Thesis</h2>
      <div class="entry">
        <p class="citation">
          Brevil, Jose F. &ldquo;[Thesis Title: A Study of Something Important].&rdquo;
          [Department], [University Name], [Year].
        </p>
        <p class="advisor">
          <span class="advisor-label">Advisor:</span> [Professor Name]
        </p>
      </div>
    </section>

    <!-- Research Experience -->
    <section class="section">
      <h2 class="section-heading">Research Experience</h2>

      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">[Research Assistant], [Lab Name]</span>
          <span class="entry-date">[Month Year] – Present</span>
        </div>
        <p class="entry-bullet">· [Conducted qualitative analysis of [data type] using [method], contributing to [project goal]]</p>
        <p class="entry-bullet">· [Assisted with [task], including [specific responsibility] and [outcome]]</p>
      </div>

      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">[Research Intern], [Organization]</span>
          <span class="entry-date">[Month Year] – [Month Year]</span>
        </div>
        <p class="entry-bullet">· [Developed [tool/framework] to analyze [data], resulting in [finding]]</p>
      </div>
    </section>

    <!-- Conference Presentations & Writing -->
    <section class="section">
      <h2 class="section-heading">Conference Presentations &amp; Writing</h2>
      <ol class="presentation-list">
        <li>
          Brevil, Jose F. &ldquo;[Paper Title].&rdquo; Presented at [Conference Name],
          [City], [Month Year].
        </li>
        <li>
          Brevil, Jose F. and [Co-Author]. &ldquo;[Paper Title].&rdquo; Poster presented at
          [Conference Name], [City], [Month Year].
        </li>
      </ol>
    </section>

  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 80px;
  padding-bottom: 60px;
  max-width: calc(var(--max-width));
}

.section {
  max-width: var(--content-width);
  margin-bottom: 56px;
}

.citation {
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 6px;
}

.advisor {
  font-size: 14px;
  color: var(--color-secondary);
}
.advisor-label {
  font-weight: 700;
  color: var(--color-secondary);
}

.presentation-list {
  padding-left: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.presentation-list li {
  font-size: 15px;
  line-height: 1.7;
}
</style>
