---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me">
  <div class="container page-content">
    <div class="about-grid">

      <!-- Left Column: Bio -->
      <div class="left-col">
        <h1 class="hero-heading" id="hero-heading">&nbsp;</h1>

        <p class="bio">
          Welcome. I’m Jose F. Brevil, Jr., a graduate of the <a href="https://themsms.org/" target="_blank" rel="noopener" class="prose-link">Mississippi School for Mathematics and Science</a> and an undergraduate student at the <a href="https://olemiss.edu/" target="_blank" rel="noopener" class="prose-link">University of Mississippi</a> pursuing a B.S. in Economics and a B.A. in <a href="https://olemiss.edu/lottleader/" target="_blank" rel="noopener" class="prose-link">Public Policy Leadership</a>, with a minor in <a href="https://olemiss.edu/departments/university-programs/intelligence-security-studies/" target="_blank" rel="noopener" class="prose-link">Intelligence and Security Studies</a>. My academic interests lie at the intersection of law, public policy, and national security, with a particular focus on international law and national security law.
        </p>

        <p class="bio">
          I am especially interested in how legal institutions shape public policy, economic development, and security strategy. Through academic study and public engagement, I seek to understand how legal frameworks can strengthen governance, support effective institutions, and expand access to opportunity.
        </p>

        <p class="bio">
          Outside the classroom, I am involved in several campus organizations and remain committed to continually expanding my knowledge in law, policy, and global affairs. These pursuits guide much of my academic and professional work.
        </p>

        <p class="bio">
          Please feel free to reach out, I always welcome the opportunity to connect!
        </p>
      </div>

      <!-- Right Sidebar: Portrait + Contact + Jump Links -->
      <aside class="sidebar">

        <img src="/profile.jpg" alt="Jose F. Brevil, Jr." class="portrait" />

        <div class="contact-card">
          <p class="contact-name">Jose F. Brevil, Jr.</p>

          <div class="contact-divider"></div>
          <a href="mailto:josebreviljr@gmail.com" class="contact-link">josebreviljr@gmail.com</a>
          <a
            href="https://linkedin.com/in/josebreviljr"
            target="_blank"
            rel="noopener"
            class="contact-link"
          >LinkedIn</a>
        </div>

        <div class="jump-card">
          <p class="jump-label">Jump to</p>
          <ul class="jump-links">
<li><a href="/experience">Experience</a></li>
            <li><a href="/cv">CV</a></li>

          </ul>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 40px;
  padding-bottom: 60px;
}

/* Two-column grid */
.about-grid {
  display: grid;
  grid-template-columns: 1fr var(--sidebar-width);
  gap: 80px;
  align-items: start;
}

/* Left column capped at readable width */
.left-col {
  max-width: var(--content-width);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

.hero-heading {
  font-family: var(--font-heading);
  font-size: 42px;
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 32px;
}

.bio {
  font-size: 16px;
  line-height: 1.75;
  margin-bottom: 20px;
  color: var(--color-text);
}

/* Sidebar */
.sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
  position: sticky;
  top: 88px;
}

.portrait {
  width: 100%;
  border-radius: 4px;
  display: block;
}

.contact-card,
.jump-card {
  border: 1px solid var(--color-border);
  padding: 20px;
  border-radius: 4px;
}

.contact-name {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 4px;
}
.contact-line {
  font-size: 13px;
  color: var(--color-secondary);
  line-height: 1.5;
}
.contact-divider {
  border-top: 1px solid var(--color-border);
  margin: 12px 0;
}
.contact-link {
  display: block;
  font-size: 13px;
  color: var(--color-accent);
  line-height: 1.8;
}

.jump-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-secondary);
  margin-bottom: 10px;
}
.jump-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.jump-links a {
  font-size: 14px;
  color: var(--color-accent);
}

@media (max-width: 900px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .sidebar { position: static; flex-direction: row; flex-wrap: wrap; }
  .contact-card, .jump-card { flex: 1; min-width: 200px; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.bio {
  opacity: 0;
}
.bio.visible {
  animation: fadeIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.prose-link {
  color: var(--color-text);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.2s, text-underline-offset 0.2s;
}
.prose-link:hover {
  color: var(--color-accent);
  text-underline-offset: 5px;
  text-decoration: underline;
}

.hero-cursor {
  display: inline-block;
  width: 2px;
  height: 0.85em;
  background: var(--color-text);
  margin-left: 3px;
  vertical-align: middle;
  animation: blink 0.8s step-end infinite;
}
</style>

<script>
  const el = document.getElementById('hero-heading')!;
  const lines = ['Aspiring public servant', 'and future legal scholar'];
  const full = lines.join('\n');
  const cursor = document.createElement('span');
  cursor.className = 'hero-cursor';

  const paras = document.querySelectorAll<HTMLElement>('.bio');
  paras.forEach((p, idx) => {
    setTimeout(() => p.classList.add('visible'), idx * 200);
  });

  let i = 0;
  el.textContent = '';
  el.appendChild(cursor);

  const timer = setInterval(() => {
    const char = full[i];
    if (char === '\n') {
      el.insertBefore(document.createElement('br'), cursor);
    } else {
      el.insertBefore(document.createTextNode(char), cursor);
    }
    i++;
    if (i >= full.length) {
      clearInterval(timer);
      setTimeout(() => cursor.remove(), 1800);
    }
  }, 55);
</script>
