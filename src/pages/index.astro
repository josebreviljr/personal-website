---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me">
  <div class="container page-content">
    <div class="about-grid">

      <!-- Left Column: Bio -->
      <div class="left-col">
        <h1 class="hero-heading">Aspiring public servant<br />and future legal scholar</h1>

        <p class="bio">
          Welcome! I am a [year, e.g., junior] studying [Major] at [University Name].
          My academic interests center on [research area 1] and [research area 2], with a
          particular focus on how legal frameworks intersect with public policy. I have had
          the opportunity to explore these topics through coursework and independent research
          under [Professor Name].
        </p>

        <p class="bio">
          Prior to [University], I [brief background — hometown, relevant pre-college
          experience]. I am currently [current role/activity — e.g., a research assistant
          in the [Lab Name] lab / working on an honors thesis titled "[Title]"].
        </p>

        <p class="bio">
          Outside the classroom, I am involved in [campus organization 1] and [campus
          organization 2]. I am also deeply committed to [personal value or cause], which
          motivates much of my academic and professional work.
        </p>
      </div>

      <!-- Right Sidebar: Portrait + Contact + Jump Links -->
      <aside class="sidebar">

        <img src="/profile.jpg" alt="Jose F. Brevil, Jr." class="portrait" />

        <div class="contact-card">
          <p class="contact-name">Jose F. Brevil, Jr.</p>
          <p class="contact-line">[University Name]</p>
          <p class="contact-line">[Major], [Year]</p>
          <div class="contact-divider"></div>
          <a href="mailto:josebreviljr@gmail.com" class="contact-link">josebreviljr@gmail.com</a>
          <a
            href="https://linkedin.com/in/josebreviljr"
            target="_blank"
            rel="noopener"
            class="contact-link"
          >LinkedIn</a>
        </div>

        <div class="jump-card">
          <p class="jump-label">Jump to</p>
          <ul class="jump-links">
            <li><a href="/research">Research &amp; Writing</a></li>
            <li><a href="/experience">Experience</a></li>
            <li><a href="/resume">Resume</a></li>
            <li><a href="#personal-note">Personal note</a></li>
          </ul>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 40px;
  padding-bottom: 60px;
}

/* Two-column grid */
.about-grid {
  display: grid;
  grid-template-columns: 1fr var(--sidebar-width);
  gap: 80px;
  align-items: start;
}

/* Left column capped at readable width */
.left-col {
  max-width: var(--content-width);
}

.hero-heading {
  font-family: var(--font-heading);
  font-size: 42px;
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 32px;
}

.bio {
  font-size: 16px;
  line-height: 1.75;
  margin-bottom: 20px;
  color: var(--color-text);
}

/* Sidebar */
.sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
  position: sticky;
  top: 88px;
}

.portrait {
  width: 100%;
  border-radius: 4px;
  display: block;
}

.contact-card,
.jump-card {
  border: 1px solid var(--color-border);
  padding: 20px;
  border-radius: 4px;
}

.contact-name {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 4px;
}
.contact-line {
  font-size: 13px;
  color: var(--color-secondary);
  line-height: 1.5;
}
.contact-divider {
  border-top: 1px solid var(--color-border);
  margin: 12px 0;
}
.contact-link {
  display: block;
  font-size: 13px;
  color: var(--color-accent);
  line-height: 1.8;
}

.jump-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-secondary);
  margin-bottom: 10px;
}
.jump-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.jump-links a {
  font-size: 14px;
  color: var(--color-accent);
}

@media (max-width: 900px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .sidebar { position: static; flex-direction: row; flex-wrap: wrap; }
  .contact-card, .jump-card { flex: 1; min-width: 200px; }
}
</style>
