---
import BaseLayout from '../layouts/BaseLayout.astro';
import bio from '../data/bio.json';
---

<BaseLayout title="About Me">
  <div class="container page-content">
    <div class="about-grid">

      <!-- Left Column: Bio -->
      <div class="left-col">
        <h1 class="hero-heading" id="hero-heading">&nbsp;</h1>

        <p class="bio">{bio.paragraph1}</p>
        <p class="bio">{bio.paragraph2}</p>
        <p class="bio">{bio.paragraph3}</p>
        <p class="bio">{bio.paragraph4}</p>
      </div>

      <!-- Right Sidebar: Portrait + Contact + Jump Links -->
      <aside class="sidebar">

        <img src="/profile.jpg" alt="Jose F. Brevil, Jr." class="portrait" />

        <div class="contact-card">
          <p class="contact-name">Jose F. Brevil, Jr.</p>

          <div class="contact-divider"></div>
          <a href={`mailto:${bio.email}`} class="contact-link">{bio.email}</a>
          <a
            href={bio.linkedinUrl}
            target="_blank"
            rel="noopener"
            class="contact-link"
          >LinkedIn</a>
        </div>

        <div class="jump-card">
          <p class="jump-label">Jump to</p>
          <ul class="jump-links">
            <li><a href="/experience">Experience</a></li>
            <li><a href="/cv">CV</a></li>
          </ul>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 40px;
  padding-bottom: 60px;
}

/* Two-column grid */
.about-grid {
  display: grid;
  grid-template-columns: 1fr var(--sidebar-width);
  gap: 80px;
  align-items: start;
}

/* Left column capped at readable width */
.left-col {
  max-width: var(--content-width);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

.hero-heading {
  font-family: var(--font-heading);
  font-size: 42px;
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 32px;
}

.bio {
  font-size: 16px;
  line-height: 1.75;
  margin-bottom: 20px;
  color: var(--color-text);
}

/* Sidebar */
.sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
  position: sticky;
  top: 88px;
}

.portrait {
  width: 100%;
  border-radius: 4px;
  display: block;
}

.contact-card,
.jump-card {
  border: 1px solid var(--color-border);
  padding: 20px;
  border-radius: 4px;
}

.contact-name {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 4px;
}
.contact-line {
  font-size: 13px;
  color: var(--color-secondary);
  line-height: 1.5;
}
.contact-divider {
  border-top: 1px solid var(--color-border);
  margin: 12px 0;
}
.contact-link {
  display: block;
  font-size: 13px;
  color: var(--color-accent);
  line-height: 1.8;
}

.jump-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-secondary);
  margin-bottom: 10px;
}
.jump-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.jump-links a {
  font-size: 14px;
  color: var(--color-accent);
}

@media (max-width: 900px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .sidebar { position: static; flex-direction: row; flex-wrap: wrap; }
  .contact-card, .jump-card { flex: 1; min-width: 200px; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.bio {
  opacity: 0;
}
.bio.visible {
  animation: fadeIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.hero-cursor {
  display: inline-block;
  width: 2px;
  height: 0.85em;
  background: var(--color-text);
  margin-left: 3px;
  vertical-align: middle;
  animation: blink 0.8s step-end infinite;
}
</style>

<script define:vars={{ heroLine1: bio.heroLine1, heroLine2: bio.heroLine2 }}>
  const el = document.getElementById('hero-heading');
  const lines = [heroLine1, heroLine2];
  const full = lines.join('\n');
  const cursor = document.createElement('span');
  cursor.className = 'hero-cursor';

  const paras = document.querySelectorAll('.bio');
  paras.forEach((p, idx) => {
    setTimeout(() => p.classList.add('visible'), idx * 200);
  });

  let i = 0;
  el.textContent = '';
  el.appendChild(cursor);

  const timer = setInterval(() => {
    const char = full[i];
    if (char === '\n') {
      el.insertBefore(document.createElement('br'), cursor);
    } else {
      el.insertBefore(document.createTextNode(char), cursor);
    }
    i++;
    if (i >= full.length) {
      clearInterval(timer);
      setTimeout(() => cursor.remove(), 1800);
    }
  }, 55);
</script>
