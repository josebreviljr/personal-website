---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="container not-found">
    <p class="nf-name">Jose F. Brevil, Jr.</p>
    <p class="nf-message">Page not found.</p>
    <a href="/" class="nf-link">← Back to home</a>
  </div>
</BaseLayout>

<style>
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 12px;
  text-align: center;
}
.nf-name {
  font-family: var(--font-heading);
  font-size: 22px;
  font-weight: 600;
}
.nf-message {
  font-size: 16px;
  color: var(--color-secondary);
}
.nf-link {
  font-size: 14px;
  color: var(--color-accent);
  margin-top: 8px;
}
</style>
