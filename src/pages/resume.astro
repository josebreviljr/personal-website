---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Résumé">
  <div class="container page-content">
    <div class="resume-header">
      <h1>Résumé</h1>
      <a href="/resume.pdf" download class="download-btn">Download Résumé</a>
    </div>

    <!-- PDF embed (built last — placeholder until resume.pdf is added to /public) -->
    <div class="pdf-wrapper">
      <p class="pdf-placeholder">
        Resume PDF will be embedded here. Add <code>resume.pdf</code> to the
        <code>public/</code> folder, then uncomment the iframe below.
      </p>
      <!--
      <iframe
        src="/resume.pdf"
        width="100%"
        height="800"
        title="Jose F. Brevil, Jr. — Résumé"
      >
        <p>
          Your browser does not support inline PDFs.
          <a href="/resume.pdf">Download the résumé instead.</a>
        </p>
      </iframe>
      -->
    </div>
  </div>
</BaseLayout>

<style>
.page-content {
  padding-top: 80px;
  padding-bottom: 60px;
  max-width: var(--content-width);
}

.resume-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 16px;
}

.download-btn {
  display: inline-block;
  padding: 10px 24px;
  background: var(--color-accent);
  color: #fff;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 700;
  border-radius: 3px;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.15s;
}
.download-btn:hover {
  opacity: 0.88;
  text-decoration: none;
}

.pdf-wrapper iframe {
  width: 100%;
  border: 1px solid var(--color-border);
  border-radius: 4px;
}

.pdf-placeholder {
  border: 1px dashed var(--color-border);
  border-radius: 4px;
  padding: 40px;
  text-align: center;
  color: var(--color-secondary);
  font-size: 14px;
}
.pdf-placeholder code {
  background: #f4f4f4;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 13px;
}
</style>
