---
const pathname = Astro.url.pathname;

const links = [
  { href: '/',           label: 'About Me'          },
  { href: '/research',   label: 'Research & Writing' },
  { href: '/experience', label: 'Experience'         },
  { href: '/resume',     label: 'Resume'             },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-name">Jose F. Brevil, Jr.</a>
    <ul class="nav-links">
      {links.map(({ href, label }) => (
        <li>
          <a href={href} class:list={['nav-link', { active: isActive(href) }]}>
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
.nav {
  background: #fff;
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}
.nav-name {
  font-family: var(--font-heading);
  font-size: 20px;
  font-weight: 600;
  color: var(--color-text);
  text-decoration: none;
  white-space: nowrap;
}
.nav-name:hover { color: var(--color-accent); }

.nav-links {
  display: flex;
  list-style: none;
  gap: 36px;
}
.nav-link {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--color-text);
  text-decoration: none;
  padding-bottom: 2px;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
}
.nav-link:hover {
  color: var(--color-accent);
  text-decoration: none;
}
.nav-link.active {
  color: var(--color-accent);
  border-bottom-color: var(--color-accent);
}

@media (max-width: 768px) {
  .nav-links { gap: 20px; }
  .nav-link { font-size: 13px; }
}
@media (max-width: 520px) {
  .nav-inner { flex-direction: column; height: auto; padding: 12px 0; gap: 10px; }
  .nav-links { gap: 16px; flex-wrap: wrap; justify-content: center; }
}
</style>
